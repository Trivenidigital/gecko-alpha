# === Scanner Config ===
SCAN_INTERVAL_SECONDS=60        # Polling interval for data sources
MIN_SCORE=60                    # Minimum quant score to trigger MiroFish
CONVICTION_THRESHOLD=70         # Minimum conviction score to fire alert
QUANT_WEIGHT=0.6                # Weight of quant score in conviction formula
NARRATIVE_WEIGHT=0.4            # Weight of narrative score in conviction formula

# === Token Filters ===
MIN_MARKET_CAP=10000            # Minimum market cap (USD)
MAX_MARKET_CAP=500000           # Maximum market cap (USD)
MAX_TOKEN_AGE_DAYS=7            # Maximum token age in days
MIN_LIQUIDITY_USD=15000         # Minimum liquidity (hard disqualifier)
MIN_VOL_LIQ_RATIO=5.0          # Minimum volume/liquidity ratio
CHAINS=solana,base,ethereum     # Comma-separated chains to scan

# === CoinGecko Signal Thresholds ===
MOMENTUM_RATIO_THRESHOLD=0.6    # 1h/24h price ratio gate for momentum signal
MIN_VOL_ACCEL_RATIO=5.0         # Volume / 7d-avg ratio gate for vol acceleration signal
COINGECKO_API_KEY=              # Optional: CoinGecko Demo API key (free tier)

# === MiroFish ===
MIROFISH_URL=http://localhost:5001
MIROFISH_TIMEOUT_SEC=180
MAX_MIROFISH_JOBS_PER_DAY=50    # Cost guard: max MiroFish simulations per day

# === Alerts ===
TELEGRAM_BOT_TOKEN=             # Required: Telegram bot token
TELEGRAM_CHAT_ID=               # Required: Telegram channel/chat ID
DISCORD_WEBHOOK_URL=            # Optional: Discord webhook URL

# === Holder Enrichment (optional) ===
HELIUS_API_KEY=                 # Helius API key for Solana holder data
MORALIS_API_KEY=                # Moralis API key for EVM holder data

# === Database ===
DB_PATH=scout.db

# === Anthropic Fallback ===
ANTHROPIC_API_KEY=              # Required: Anthropic API key for fallback scorer

# === Narrative Rotation Agent ===
NARRATIVE_ENABLED=false
NARRATIVE_POLL_INTERVAL=1800
NARRATIVE_EVAL_INTERVAL=21600
NARRATIVE_SCORING_MODEL=claude-haiku-4-5
NARRATIVE_LEARN_MODEL=claude-sonnet-4-6
NARRATIVE_SNAPSHOT_RETENTION_DAYS=7
NARRATIVE_LEARN_HOUR_UTC=1
NARRATIVE_WEEKLY_LEARN_DAY=6
NARRATIVE_DIGEST_HOUR_UTC=0

# === Counter-Narrative Scoring ===
COUNTER_ENABLED=true
COUNTER_MODEL=claude-haiku-4-5
COUNTER_SUPPRESS_THRESHOLD=100

# === Conviction Chains ===
CHAINS_ENABLED=false
CHAIN_CHECK_INTERVAL_SEC=300
CHAIN_MAX_WINDOW_HOURS=24.0
CHAIN_COOLDOWN_HOURS=12.0
CHAIN_EVENT_RETENTION_DAYS=14
CHAIN_ACTIVE_RETENTION_DAYS=7
CHAIN_ALERT_ON_COMPLETE=true
CHAIN_TOTAL_BOOST_CAP=30
# LEARN phase lifecycle
CHAIN_MIN_TRIGGERS_FOR_STATS=10
CHAIN_PROMOTION_THRESHOLD=0.45
CHAIN_GRADUATION_MIN_TRIGGERS=30
CHAIN_GRADUATION_HIT_RATE=0.55

# --- Second-Wave Detection ---
SECONDWAVE_ENABLED=false
SECONDWAVE_POLL_INTERVAL=1800
SECONDWAVE_MIN_PRIOR_SCORE=60
SECONDWAVE_COOLDOWN_MIN_DAYS=3
SECONDWAVE_COOLDOWN_MAX_DAYS=14
SECONDWAVE_MIN_DRAWDOWN_PCT=30.0
SECONDWAVE_MIN_RECOVERY_PCT=70.0
SECONDWAVE_VOL_PICKUP_RATIO=2.0
SECONDWAVE_ALERT_THRESHOLD=50
SECONDWAVE_DEDUP_DAYS=7

# === Market Briefing Agent ===
BRIEFING_ENABLED=false
BRIEFING_HOURS_UTC=6,18
BRIEFING_MODEL=claude-sonnet-4-6
BRIEFING_TELEGRAM_ENABLED=true
COINGLASS_API_KEY=              # Optional: CoinGlass API key (free tier)

# === GeckoTerminal Per-Chain Trending (BL-052) ===
# Rank threshold for the gt_trending scoring signal (+15 pts).
# Lower = stricter; default 10 = top half of GT's ~20-per-chain list.
GT_TRENDING_TOP_N=10

# === Paper Trading Engine ===
TRADING_ENABLED=false
TRADING_MODE=paper
PAPER_TRADE_AMOUNT_USD=1000.0
PAPER_MAX_EXPOSURE_USD=10000.0
PAPER_TP_PCT=20.0
PAPER_SL_PCT=10.0
PAPER_MAX_DURATION_HOURS=48
PAPER_SLIPPAGE_BPS=50
TRADING_DIGEST_HOUR_UTC=0
TRADING_EVAL_INTERVAL=1800

# === CryptoPanic News Feed (BL-053) ===
# Research-only: tags candidate tokens with news context. Free token required
# (https://cryptopanic.com/developers/api/keys — leave blank to disable).
CRYPTOPANIC_ENABLED=false
CRYPTOPANIC_API_TOKEN=
CRYPTOPANIC_FETCH_FILTER=hot
CRYPTOPANIC_MACRO_MIN_CURRENCIES=4
CRYPTOPANIC_SCORING_ENABLED=false
CRYPTOPANIC_RETENTION_DAYS=7

# --- Live Trading (BL-055) --- default: paper (unchanged)
# See docs/live-mode-setup.md before flipping. Every line below is commented on
# purpose — uncomment and edit only when operating live mode per spec §11.8.
# LIVE_MODE=paper                          # paper | shadow | live
# LIVE_TRADE_AMOUNT_USD=100
# LIVE_SIGNAL_SIZES=                       # e.g. first_signal=50,gainers_early=75
# LIVE_TP_PCT=                             # blank = inherit PAPER_TP_PCT
# LIVE_SL_PCT=                             # blank = inherit PAPER_SL_PCT
# LIVE_MAX_DURATION_HOURS=                 # blank = inherit PAPER_MAX_DURATION_HOURS
# LIVE_SLIPPAGE_BPS_CAP=50
# LIVE_DEPTH_HEALTH_MULTIPLIER=3
# LIVE_VENUE_PREFERENCE=binance            # CSV in v2; v1 is Binance-only
# LIVE_DAILY_LOSS_CAP_USD=50
# LIVE_MAX_EXPOSURE_USD=500
# LIVE_MAX_OPEN_POSITIONS=5
# LIVE_SIGNAL_ALLOWLIST=                   # e.g. first_signal,gainers_early
#
# Credentials — DO NOT paste real keys into this file (it is committed).
# Set these only in the VPS `.env` (gitignored). See docs/live-mode-setup.md.
# BINANCE_API_KEY=your_api_key_here
# BINANCE_API_SECRET=your_api_secret_here
